---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { useTranslations, localePath } from "../i18n";

interface Props {
  locale: string;
  path: string;
  current?: "process" | "pricing" | "about" | "faq" | "casinos" | "verify";
}

const { locale, path, current } = Astro.props;
const t = useTranslations(locale);

const navItems: { key: NonNullable<Props["current"]>; href: string; label: string }[] = [
  { key: "process", href: "/how-it-works/", label: t.nav.howItWorks },
  { key: "pricing", href: "/pricing/", label: t.nav.pricing },
  { key: "about", href: "/about/", label: t.nav.about },
  { key: "faq", href: "/faq/", label: t.nav.faq },
  { key: "casinos", href: "/casinos/", label: t.nav.casinos },
  { key: "verify", href: "/verify/", label: t.nav.verify },
];

const shieldPath = "M12 2L4 5V11C4 16.5 7.5 20.7 12 22C16.5 20.7 20 16.5 20 11V5L12 2Z";
const boltPath = "M13 6.5L8.5 13H11.5L10.5 17.5L15.5 11H12.5L13 6.5Z";

const linkClass = (key: Props["current"]) =>
  current === key ? "font-semibold text-[oklch(30%_0.1_155)]" : "text-inherit hover:text-ink";
---

<header class="sticky top-0 z-20 border-b border-line-soft bg-[oklch(99%_0.003_250/0.92)] backdrop-blur-sm">
  <div class="flex items-center justify-between gap-3 px-5 py-3.5 sm:px-[clamp(20px,5vw,40px)]">
    <a href={localePath("/", locale)} class="flex shrink-0 items-center gap-2.5">
      <div class="flex size-8 shrink-0 items-center justify-center rounded-lg bg-navy">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d={shieldPath} fill="oklch(70% 0.15 155)" />
          <path d={boltPath} fill="var(--color-navy)" />
        </svg>
      </div>
      <span class="text-[17px] font-bold tracking-tight text-ink">Swift Secure</span>
    </a>

    <!-- Full nav, shown once there is room for every item without scrolling. -->
    <nav class="hidden items-center gap-4 text-sm font-medium text-[oklch(35%_0.02_250)] lg:flex" aria-label={t.nav.primaryLabel}>
      {
        navItems.map((item) => (
          <a
            href={localePath(item.href, locale)}
            class:list={["whitespace-nowrap", linkClass(item.key)]}
            aria-current={current === item.key ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a href={localePath("/apply/", locale)} class="whitespace-nowrap rounded-lg bg-navy px-3.5 py-2.5 font-semibold text-white">
        {t.nav.apply}
      </a>
      <LanguageSwitcher locale={locale} path={path} />
    </nav>

    <!-- Apply stays in the always-visible bar on mobile; the language switcher
         moves into the panel below. There is only room for one of them beside
         the logo, and Apply is the action the page exists to drive. -->
    <div class="flex items-center gap-2 lg:hidden">
      <a href={localePath("/apply/", locale)} class="whitespace-nowrap rounded-lg bg-navy px-3.5 py-2 text-sm font-semibold text-white">
        {t.nav.apply}
      </a>
      <button
        type="button"
        data-nav-toggle
        aria-controls="site-nav"
        aria-expanded="false"
        aria-label={t.nav.openMenu}
        data-label-open={t.nav.openMenu}
        data-label-close={t.nav.closeMenu}
        class="flex size-9 items-center justify-center rounded-lg border border-line text-ink"
      >
        <span data-nav-icon-open class="flex">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
        <span data-nav-icon-close class="flex" hidden>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </button>
    </div>
  </div>

  <nav id="site-nav" data-nav-menu hidden class="border-t border-line-soft px-5 pb-4 pt-2 lg:hidden" aria-label={t.nav.primaryLabel}>
    {
      navItems.map((item) => (
        <a
          href={localePath(item.href, locale)}
          class:list={["block border-b border-line-soft/60 py-3 text-[15px] font-medium", linkClass(item.key)]}
          aria-current={current === item.key ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
    <div class="mt-4">
      <LanguageSwitcher locale={locale} path={path} />
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-nav-menu]");
  const iconOpen = document.querySelector<HTMLElement>("[data-nav-icon-open]");
  const iconClose = document.querySelector<HTMLElement>("[data-nav-icon-close]");

  if (toggle && menu && iconOpen && iconClose) {
    const setOpen = (open: boolean) => {
      menu.hidden = !open;
      iconOpen.hidden = open;
      iconClose.hidden = !open;
      toggle.setAttribute("aria-expanded", String(open));
      const label = open ? toggle.dataset.labelClose : toggle.dataset.labelOpen;
      if (label) toggle.setAttribute("aria-label", label);
    };

    toggle.addEventListener("click", () => setOpen(menu.hidden !== false));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && menu.hidden === false) {
        setOpen(false);
        toggle.focus();
      }
    });

    // Leaving the mobile breakpoint while the panel is open would otherwise
    // strand it visible behind the desktop nav on the next resize back down.
    const wide = window.matchMedia("(min-width: 1024px)");
    wide.addEventListener("change", (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>
