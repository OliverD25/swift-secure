---
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  current?: "process" | "pricing" | "about" | "faq" | "casinos" | "verify";
}

const { current } = Astro.props;

const navItems: { key: NonNullable<Props["current"]>; href: string; label: string }[] = [
  { key: "process", href: "/how-it-works/", label: "How it works" },
  { key: "pricing", href: "/pricing/", label: "Pricing" },
  { key: "about", href: "/about/", label: "About" },
  { key: "faq", href: "/faq/", label: "FAQ" },
  { key: "casinos", href: "/casinos/", label: "Casinos" },
  { key: "verify", href: "/verify/", label: "Verify" },
];

const shieldPath = "M12 2L4 5V11C4 16.5 7.5 20.7 12 22C16.5 20.7 20 16.5 20 11V5L12 2Z";
const boltPath = "M13 6.5L8.5 13H11.5L10.5 17.5L15.5 11H12.5L13 6.5Z";
---

<header class="sticky top-0 z-20 flex items-center justify-between gap-4 border-b border-line-soft bg-[oklch(99%_0.003_250/0.9)] px-5 py-4 backdrop-blur-sm sm:px-[clamp(20px,5vw,40px)]">
  <a href="/" class="flex shrink-0 items-center gap-2.5">
    <div class="flex size-8 items-center justify-center rounded-lg bg-navy">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d={shieldPath} fill="oklch(70% 0.15 155)" />
        <path d={boltPath} fill="var(--color-navy)" />
      </svg>
    </div>
    <span class="text-lg font-bold tracking-tight text-ink">Certified &amp; Secure</span>
  </a>

  <nav class="no-scrollbar flex min-w-0 shrink items-center gap-4 overflow-x-auto text-sm font-medium text-[oklch(35%_0.02_250)]" aria-label="Primary">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class:list={["whitespace-nowrap", current === item.key ? "font-semibold text-[oklch(30%_0.1_155)]" : "text-inherit hover:text-ink"]}
          aria-current={current === item.key ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
    <a href="/apply/" class="whitespace-nowrap rounded-lg bg-navy px-3.5 py-2.5 font-semibold text-white">Apply</a>
    <LanguageSwitcher />
  </nav>
</header>
