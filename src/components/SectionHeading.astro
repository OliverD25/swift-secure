---
interface Props {
  eyebrow: string;
  title: string;
  class?: string;
}

const { eyebrow, title, class: className = "" } = Astro.props;
---

<div class:list={["mx-auto mb-14 max-w-[640px] text-center", className]}>
  <div class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(50%_0.13_155)]">{eyebrow}</div>
  <h2 class="text-[32px] font-extrabold tracking-tight sm:text-4xl">{title}</h2>
</div>
