---
import { languages, defaultLanguage } from "../data/languages";

const flagUrl = (iso: string) => `https://flagcdn.com/w40/${iso}.png`;
---

<div class="relative" data-lang-switcher>
  <button
    type="button"
    data-lang-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
    class="flex items-center gap-1.5 whitespace-nowrap rounded-full bg-[oklch(20%_0.01_250)] px-2.5 py-1.5 text-[13px] font-semibold text-white"
  >
    <span class="inline-block size-[18px] shrink-0 overflow-hidden rounded-full">
      <img
        data-lang-flag
        src={flagUrl(defaultLanguage.iso)}
        alt={defaultLanguage.code}
        width="18"
        height="18"
        decoding="async"
        class="size-full object-cover"
      />
    </span>
    <span data-lang-code>{defaultLanguage.code}</span>
    <span class="text-[9px] opacity-70">&#9662;</span>
  </button>

  <div
    data-lang-menu
    role="listbox"
    hidden
    class="absolute right-0 top-[calc(100%+8px)] z-30 max-h-[420px] w-[220px] overflow-y-auto rounded-2xl bg-[oklch(16%_0.01_250)] p-2.5 shadow-[0_20px_50px_-12px_oklch(0%_0_0/0.4)]"
  >
    {
      languages.map((lang) => (
        <button
          type="button"
          data-lang-option
          data-code={lang.code}
          data-name={lang.name}
          data-flag-src={flagUrl(lang.iso)}
          class="flex w-full items-center gap-2.5 rounded-lg px-2.5 py-2.5 text-left text-sm font-medium text-[oklch(92%_0.005_250)] hover:bg-[oklch(24%_0.01_250)]"
        >
          <span class="inline-block size-5 shrink-0 overflow-hidden rounded-full">
            <img src={flagUrl(lang.iso)} alt={lang.code} width="20" height="20" loading="lazy" decoding="async" class="size-full object-cover" />
          </span>
          {lang.name}
        </button>
      ))
    }
  </div>
</div>

<script>
  const STORAGE_KEY = "swiftsecure:lang";

  document.querySelectorAll<HTMLElement>("[data-lang-switcher]").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>("[data-lang-trigger]");
    const menu = root.querySelector<HTMLElement>("[data-lang-menu]");
    const flagImg = root.querySelector<HTMLImageElement>("[data-lang-flag]");
    const codeLabel = root.querySelector<HTMLElement>("[data-lang-code]");
    if (!trigger || !menu || !flagImg || !codeLabel) return;

    const close = () => {
      menu.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
    };

    const open = () => {
      menu.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
    };

    trigger.addEventListener("click", (event) => {
      event.stopPropagation();
      menu.hidden ? open() : close();
    });

    menu.querySelectorAll<HTMLButtonElement>("[data-lang-option]").forEach((option) => {
      option.addEventListener("click", () => {
        const code = option.dataset.code!;
        const name = option.dataset.name!;
        const flagSrc = option.dataset.flagSrc!;
        flagImg.src = flagSrc;
        flagImg.alt = code;
        codeLabel.textContent = code;
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ code, name, flagSrc }));
        close();
      });
    });

    document.addEventListener("click", (event) => {
      if (!root.contains(event.target as Node)) close();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close();
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const { code, flagSrc } = JSON.parse(saved);
        if (code && flagSrc) {
          flagImg.src = flagSrc;
          flagImg.alt = code;
          codeLabel.textContent = code;
        }
      }
    } catch {
      /* ignore malformed storage */
    }
  });
</script>
