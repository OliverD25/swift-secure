---
import { languages, flagUrl } from "../data/languages";
import { localePath, getLanguage } from "../i18n";

interface Props {
  locale: string;
  /** Route without locale prefix, so switching keeps the visitor on this page. */
  path: string;
}

const { locale, path } = Astro.props;
const current = getLanguage(locale);
---

<div class="relative" data-lang-switcher>
  <button
    type="button"
    data-lang-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
    class="flex items-center gap-1.5 whitespace-nowrap rounded-full bg-[oklch(20%_0.01_250)] px-2.5 py-1.5 text-[13px] font-semibold text-white"
  >
    <span class="inline-block size-[18px] shrink-0 overflow-hidden rounded-full">
      <img src={flagUrl(current.iso)} alt="" width="18" height="18" decoding="async" class="size-full object-cover" />
    </span>
    <span>{current.code}</span>
    <span class="text-[9px] opacity-70">&#9662;</span>
  </button>

  <div
    data-lang-menu
    role="listbox"
    hidden
    class="absolute end-0 top-[calc(100%+8px)] z-30 max-h-[420px] w-[220px] overflow-y-auto rounded-2xl bg-[oklch(16%_0.01_250)] p-2.5 text-start shadow-[0_20px_50px_-12px_oklch(0%_0_0/0.4)]"
  >
    {
      languages.map((lang) => (
        <a
          href={localePath(path, lang.locale)}
          hreflang={lang.htmlLang}
          lang={lang.htmlLang}
          role="option"
          aria-selected={lang.locale === locale ? "true" : "false"}
          class:list={[
            "flex w-full items-center gap-2.5 rounded-lg px-2.5 py-2.5 text-sm font-medium hover:bg-[oklch(24%_0.01_250)]",
            lang.locale === locale ? "text-white" : "text-[oklch(92%_0.005_250)]",
          ]}
        >
          <span class="inline-block size-5 shrink-0 overflow-hidden rounded-full">
            <img src={flagUrl(lang.iso)} alt="" width="20" height="20" loading="lazy" decoding="async" class="size-full object-cover" />
          </span>
          {lang.name}
        </a>
      ))
    }
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-lang-switcher]").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>("[data-lang-trigger]");
    const menu = root.querySelector<HTMLElement>("[data-lang-menu]");
    if (!trigger || !menu) return;

    const close = () => {
      menu.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
    };

    trigger.addEventListener("click", (event) => {
      event.stopPropagation();
      const open = menu.hidden !== false;
      menu.hidden = !open;
      trigger.setAttribute("aria-expanded", String(open));
    });

    document.addEventListener("click", (event) => {
      if (!root.contains(event.target as Node)) close();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close();
    });
  });
</script>
