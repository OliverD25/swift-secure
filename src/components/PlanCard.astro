---
import type { Plan } from "../data/content";

interface Props {
  plan: Plan;
  featuresCount?: number;
}

const { plan, featuresCount } = Astro.props;
const features = featuresCount ? plan.features.slice(0, featuresCount) : plan.features;
---

<div
  class:list={[
    "relative rounded-2xl bg-white p-7 sm:p-8",
    plan.featured ? "border-2 border-emerald" : "border border-line",
  ]}
>
  {
    plan.featured && (
      <div class="absolute -top-3 left-7 rounded-md bg-emerald px-2.5 py-1 text-[11px] font-bold tracking-[0.03em] text-white">
        MOST POPULAR
      </div>
    )
  }
  <div class="mb-1.5 text-lg font-bold">{plan.name}</div>
  <div class="mb-1 text-[34px] font-extrabold">{plan.price}</div>
  <div class="mb-5.5 text-[13px] text-ink-muted">{plan.cadence}</div>
  <div class="mb-6.5 flex flex-col gap-2.5">
    {
      features.map((f) => (
        <div class="flex gap-2 text-sm text-[oklch(30%_0.02_250)]">
          <span class="text-emerald">&#10003;</span>
          {f}
        </div>
      ))
    }
  </div>
  <a
    href="/apply/"
    class:list={[
      "block rounded-lg py-3 text-center text-sm font-semibold",
      plan.featured ? "bg-navy text-white" : "bg-surface-alt text-[oklch(25%_0.02_250)]",
    ]}
  >
    Apply now
  </a>
</div>
