---
import { stats } from "../data/content";

interface Props {
  variant?: "dark" | "light";
}

const { variant = "dark" } = Astro.props;
---

<div class="grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-6 text-center">
  {
    stats.map((s) => (
      <div>
        <div class:list={["text-[32px] font-extrabold", variant === "dark" ? "text-white" : "text-navy"]}>{s.value}</div>
        <div class:list={["mt-1 text-sm", variant === "dark" ? "text-[oklch(80%_0.02_250)]" : "text-ink-muted"]}>{s.label}</div>
      </div>
    ))
  }
</div>
