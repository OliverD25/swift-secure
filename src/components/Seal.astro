---
import { useTranslations } from "../i18n";

interface Props {
  locale: string;
  variant?: "primary" | "compact" | "dark";
  size?: number;
  class?: string;
}

const { locale, variant = "primary", size, class: className = "" } = Astro.props;
const t = useTranslations(locale);

const shieldPath = "M12 2L4 5V11C4 16.5 7.5 20.7 12 22C16.5 20.7 20 16.5 20 11V5L12 2Z";
const boltPath = "M13 6.5L8.5 13H11.5L10.5 17.5L15.5 11H12.5L13 6.5Z";

const diameter = size ?? (variant === "dark" ? 160 : 200);
const iconSize = variant === "dark" ? 38 : 46;
---

{
  variant === "compact" ? (
    <div
      class:list={[
        "inline-flex items-center gap-2.5 rounded-full border-[1.5px] border-[oklch(85%_0.02_155)] bg-white px-4.5 py-2.5",
        className,
      ]}
    >
      <div class="flex size-7 shrink-0 items-center justify-center rounded-lg bg-emerald">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d={boltPath} fill="white" />
        </svg>
      </div>
      <span class="text-sm font-bold text-[oklch(25%_0.05_250)]">Swift Secure</span>
      <span class="text-xs font-semibold text-ink-muted">{t.seal.certified}</span>
    </div>
  ) : (
    <div
      class:list={[
        "flex flex-col items-center justify-center gap-2 rounded-full text-center",
        variant === "dark" ? "border-2 border-[oklch(60%_0.15_155)]" : "border-[3px] border-emerald bg-white",
        className,
      ]}
      style={{ width: `${diameter}px`, height: `${diameter}px` }}
    >
      <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" aria-hidden="true">
        {variant === "dark" ? (
          <>
            <path d={shieldPath} stroke="oklch(65% 0.15 155)" stroke-width="1.4" />
            <path d={boltPath} fill="oklch(65% 0.15 155)" />
          </>
        ) : (
          <>
            <path d={shieldPath} fill="var(--color-emerald)" />
            <path d={boltPath} fill="white" />
          </>
        )}
      </svg>
      <span
        class:list={[
          "px-2 text-sm font-extrabold tracking-wide",
          variant === "dark" ? "text-white" : "text-[oklch(25%_0.05_250)]",
        ]}
      >
        SWIFT SECURE
      </span>
      <span
        class:list={[
          // Uppercased in CSS rather than in the copy, so the browser applies
          // each locale's own casing rules (e.g. Turkish i → İ) and scripts
          // without case are left untouched.
          "px-2 text-[10px] font-semibold uppercase tracking-[0.1em]",
          variant === "dark" ? "text-[oklch(70%_0.02_250)]" : "text-[oklch(55%_0.02_250)]",
        ]}
      >
        {t.seal.certified}
      </span>
    </div>
  )
}
