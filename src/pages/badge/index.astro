---
import Layout from "../../layouts/Layout.astro";
import Seal from "../../components/Seal.astro";
import CtaBand from "../../components/CtaBand.astro";

const title = "The Swift Secure Seal";
const description = "Brand reference for the Swift Secure certification seal: primary badge, compact lockup, and dark-background variant.";
---

<Layout title={title} description={description} noIndex>
  <main>
    <section class="mx-auto w-full max-w-[720px] px-[clamp(20px,5vw,40px)] pb-5 pt-18 text-center">
      <div class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(50%_0.13_155)]">The seal</div>
      <h1 class="mb-4 text-[38px] font-extrabold tracking-tight">Swift Secure</h1>
      <p class="text-base leading-relaxed text-ink-muted">
        One badge, three forms. Simple enough to sit next to a footer logo, clear enough to mean something at a glance.
      </p>
    </section>

    <!-- PRIMARY SEAL -->
    <section class="mx-auto grid w-full max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] items-center gap-12 px-[clamp(20px,5vw,40px)] py-10">
      <div class="flex items-center justify-center rounded-[20px] border border-[oklch(91%_0.01_250)] bg-white p-15">
        <Seal variant="primary" />
      </div>
      <div>
        <div class="mb-2.5 text-lg font-bold">Primary seal</div>
        <div class="mb-4 text-sm leading-relaxed text-ink-muted">
          The full badge, for a homepage hero or footer. One weight of stroke, one accent color, no gradients or extra ornament &mdash; it has
          to read clearly at any size, even shrunk to 60px.
        </div>
        <div class="flex flex-wrap gap-2">
          <div class="rounded-full bg-[oklch(94%_0.04_155)] px-2.5 py-1.5 text-xs font-semibold text-[oklch(35%_0.1_155)]">200 &times; 200px</div>
          <div class="rounded-full bg-[oklch(94%_0.006_250)] px-2.5 py-1.5 text-xs font-semibold text-[oklch(40%_0.02_250)]">SVG / PNG</div>
        </div>
      </div>
    </section>

    <!-- COMPACT LOCKUP -->
    <section class="bg-surface-alt px-[clamp(20px,5vw,40px)] py-15">
      <div class="mx-auto grid max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] items-center gap-12">
        <div>
          <div class="mb-2.5 text-lg font-bold">Compact lockup</div>
          <div class="text-sm leading-relaxed text-ink-muted">
            For a checkout page, footer strip, or anywhere horizontal space is tight. Same icon, same wordmark, one line.
          </div>
        </div>
        <div class="flex items-center justify-center rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-8">
          <Seal variant="compact" />
        </div>
      </div>
    </section>

    <!-- DARK / MONOCHROME -->
    <section class="mx-auto grid w-full max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] items-center gap-12 px-[clamp(20px,5vw,40px)] py-15">
      <div class="flex items-center justify-center rounded-[20px] bg-[oklch(18%_0.02_250)] p-15">
        <Seal variant="dark" />
      </div>
      <div>
        <div class="mb-2.5 text-lg font-bold">Dark-background variant</div>
        <div class="text-sm leading-relaxed text-ink-muted">
          For casino sites with dark themes: the ring switches to an outlined icon and white type so it stays legible without needing a white
          plate behind it.
        </div>
      </div>
    </section>

    <CtaBand heading="Want to display Swift Secure on your site?" ctaLabel="Apply for Certification" ctaHref="/apply/" />
  </main>
</Layout>
