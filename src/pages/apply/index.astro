---
import Layout from "../../layouts/Layout.astro";

const title = "Apply for Certification";
const description = "Get your Swift Secure seal in as little as 10 days. Tell us about your platform — our compliance team responds within 48 hours.";
---

<Layout title={title} description={description}>
  <main>
    <section class="mx-auto w-full max-w-[640px] px-6 py-16">
      <div class="mb-9">
        <div class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(50%_0.13_155)]">Apply for certification</div>
        <h1 class="mb-2.5 text-[32px] font-extrabold tracking-tight">Get your seal in as little as 10 days</h1>
        <p class="text-[15px] text-ink-muted">Tell us about your platform. Our compliance team responds within 48 hours.</p>
      </div>

      <form data-apply-form class="flex flex-col gap-4.5" novalidate>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-[13px] font-semibold text-[oklch(35%_0.02_250)]">Casino name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Northgate Interactive"
              class="rounded-lg border border-[oklch(85%_0.01_250)] px-3.5 py-3 text-sm font-sans placeholder:text-[oklch(65%_0.01_250)]"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="website" class="text-[13px] font-semibold text-[oklch(35%_0.02_250)]">Website URL</label>
            <input
              id="website"
              name="website"
              type="url"
              required
              placeholder="https://"
              class="rounded-lg border border-[oklch(85%_0.01_250)] px-3.5 py-3 text-sm font-sans placeholder:text-[oklch(65%_0.01_250)]"
            />
          </div>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="jurisdiction" class="text-[13px] font-semibold text-[oklch(35%_0.02_250)]">Licensing jurisdiction</label>
            <input
              id="jurisdiction"
              name="jurisdiction"
              type="text"
              required
              placeholder="e.g. Malta, Curacao"
              class="rounded-lg border border-[oklch(85%_0.01_250)] px-3.5 py-3 text-sm font-sans placeholder:text-[oklch(65%_0.01_250)]"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-[13px] font-semibold text-[oklch(35%_0.02_250)]">Contact email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="you@company.com"
              class="rounded-lg border border-[oklch(85%_0.01_250)] px-3.5 py-3 text-sm font-sans placeholder:text-[oklch(65%_0.01_250)]"
            />
          </div>
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="message" class="text-[13px] font-semibold text-[oklch(35%_0.02_250)]">Anything else we should know?</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Launch date, target markets, current audits..."
            class="resize-y rounded-lg border border-[oklch(85%_0.01_250)] px-3.5 py-3 text-sm font-sans placeholder:text-[oklch(65%_0.01_250)]"
          ></textarea>
        </div>
        <button type="submit" class="mt-1.5 rounded-[10px] bg-navy py-4 text-[15px] font-semibold text-white">Submit application</button>
      </form>

      <div data-apply-success hidden class="rounded-2xl border border-[oklch(80%_0.06_155)] bg-[oklch(94%_0.04_155)] px-6 py-12 text-center">
        <div class="mx-auto mb-4 flex size-12 items-center justify-center rounded-full bg-emerald text-[22px] font-bold text-white">&#10003;</div>
        <div class="mb-2 text-[19px] font-bold">Application received</div>
        <div class="text-sm text-[oklch(35%_0.06_155)]">
          Our team will reach out to <span data-apply-email>you</span> within 48 hours to start the audit.
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-apply-form]");
  const success = document.querySelector<HTMLElement>("[data-apply-success]");
  const emailSpan = document.querySelector<HTMLElement>("[data-apply-email]");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;

    const email = (form.querySelector<HTMLInputElement>("#email")?.value ?? "").trim();
    if (emailSpan && email) emailSpan.textContent = email;

    // TODO: wire this up to real submission handling (API route, email, or CRM)
    // before launch — this currently only swaps in a client-side confirmation.
    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>
