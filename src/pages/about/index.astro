---
import Layout from "../../layouts/Layout.astro";
import StatRow from "../../components/StatRow.astro";
import { team } from "../../data/content";

const title = "About Us";
const description = "An independent check on new casinos, since 2020. We built the audit that both players and casinos trust.";
---

<Layout title={title} description={description} current="about">
  <main>
    <section class="mx-auto w-full max-w-[760px] px-[clamp(20px,5vw,40px)] pb-7.5 pt-18 text-center">
      <div class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(50%_0.13_155)]">About us</div>
      <h1 class="mb-4 text-4xl font-extrabold tracking-tight">An independent check on new casinos, since 2020</h1>
      <p class="text-lg leading-relaxed text-ink-muted">
        We started because players had no fast way to tell a legitimate new operator from a shell site. We built the audit players and casinos both trust.
      </p>
    </section>

    <section class="mx-auto grid w-full max-w-[900px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-8 px-[clamp(20px,5vw,40px)] py-7.5">
      <div class="rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-7">
        <div class="mb-2.5 text-lg font-bold">Independent by design</div>
        <div class="text-sm leading-relaxed text-ink-muted">
          We take no revenue share or referral fees from certified operators. The audit fee is flat, so our findings can't be bought.
        </div>
      </div>
      <div class="rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-7">
        <div class="mb-2.5 text-lg font-bold">Rigorous, not slow</div>
        <div class="text-sm leading-relaxed text-ink-muted">
          Our audit team is ex-regulators and RNG engineers. We built the process to be thorough in days, not months.
        </div>
      </div>
    </section>

    <section class="bg-surface-alt px-[clamp(20px,5vw,40px)] py-17.5">
      <div class="mx-auto max-w-[1100px]">
        <div class="mx-auto mb-11 max-w-[600px] text-center">
          <h2 class="text-[32px] font-extrabold tracking-tight">The audit team</h2>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(230px,1fr))] gap-6">
          {
            team.map((m) => (
              <div class="rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-6 text-center">
                <div class="mx-auto mb-3.5 flex size-16 items-center justify-center rounded-full bg-[oklch(90%_0.02_155)] text-xl font-extrabold text-[oklch(35%_0.1_155)]">
                  {m.initials}
                </div>
                <div class="mb-0.5 text-base font-bold">{m.name}</div>
                <div class="mb-2.5 text-[13px] font-semibold text-[oklch(50%_0.13_155)]">{m.role}</div>
                <div class="text-[13px] leading-relaxed text-ink-muted">{m.bio}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[1280px] px-[clamp(20px,5vw,40px)] py-17.5">
      <StatRow variant="light" />
    </section>
  </main>
</Layout>
