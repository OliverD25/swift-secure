---
import Layout from "../../layouts/Layout.astro";
import StatRow from "../../components/StatRow.astro";
import { useTranslations, localeStaticPaths } from "../../i18n";

export const getStaticPaths = () => localeStaticPaths();

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Layout locale={locale} path="/about/" title={t.about.title} description={t.about.description} current="about">
  <main>
    <section class="mx-auto w-full max-w-[760px] px-[clamp(20px,5vw,40px)] pb-7.5 pt-18 text-center">
      <div class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(50%_0.13_155)]">{t.about.eyebrow}</div>
      <h1 class="mb-4 text-4xl font-extrabold tracking-tight">{t.about.h1}</h1>
      <p class="text-lg leading-relaxed text-ink-muted">{t.about.sub}</p>
    </section>

    <section class="mx-auto grid w-full max-w-[900px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-8 px-[clamp(20px,5vw,40px)] py-7.5">
      <div class="rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-7">
        <div class="mb-2.5 text-lg font-bold">{t.about.card1Title}</div>
        <div class="text-sm leading-relaxed text-ink-muted">{t.about.card1Body}</div>
      </div>
      <div class="rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-7">
        <div class="mb-2.5 text-lg font-bold">{t.about.card2Title}</div>
        <div class="text-sm leading-relaxed text-ink-muted">{t.about.card2Body}</div>
      </div>
    </section>

    <section class="bg-surface-alt px-[clamp(20px,5vw,40px)] py-17.5">
      <div class="mx-auto max-w-[1100px]">
        <div class="mx-auto mb-11 max-w-[600px] text-center">
          <h2 class="text-[32px] font-extrabold tracking-tight">{t.about.teamTitle}</h2>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(230px,1fr))] gap-6">
          {
            t.team.map((m) => (
              <div class="rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-6 text-center">
                <div class="mx-auto mb-3.5 flex size-16 items-center justify-center rounded-full bg-[oklch(90%_0.02_155)] text-xl font-extrabold text-[oklch(35%_0.1_155)]">
                  {m.initials}
                </div>
                <div class="mb-0.5 text-base font-bold">{m.name}</div>
                <div class="mb-2.5 text-[13px] font-semibold text-[oklch(50%_0.13_155)]">{m.role}</div>
                <div class="text-[13px] leading-relaxed text-ink-muted">{m.bio}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-[1280px] px-[clamp(20px,5vw,40px)] py-17.5">
      <StatRow locale={locale} variant="light" />
    </section>
  </main>
</Layout>
