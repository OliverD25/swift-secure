---
import Layout from "../../layouts/Layout.astro";
import Seal from "../../components/Seal.astro";
import CtaBand from "../../components/CtaBand.astro";
import { useTranslations, localeStaticPaths } from "../../i18n";

export const getStaticPaths = () => localeStaticPaths();

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Layout locale={locale} path="/badge/" title={t.badge.title} description={t.badge.description}>
  <main>
    <section class="mx-auto w-full max-w-[720px] px-[clamp(20px,5vw,40px)] pb-5 pt-18 text-center">
      <div class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(50%_0.13_155)]">{t.badge.eyebrow}</div>
      <h1 class="mb-4 text-[38px] font-extrabold tracking-tight">{t.badge.h1}</h1>
      <p class="text-base leading-relaxed text-ink-muted">{t.badge.sub}</p>
    </section>

    <!-- PRIMARY SEAL -->
    <section class="mx-auto grid w-full max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] items-center gap-12 px-[clamp(20px,5vw,40px)] py-10">
      <div class="flex items-center justify-center rounded-[20px] border border-[oklch(91%_0.01_250)] bg-white p-15">
        <Seal locale={locale} variant="primary" />
      </div>
      <div>
        <div class="mb-2.5 text-lg font-bold">{t.badge.primaryTitle}</div>
        <div class="mb-4 text-sm leading-relaxed text-ink-muted">{t.badge.primaryBody}</div>
        <div class="flex flex-wrap gap-2">
          <div class="rounded-full bg-[oklch(94%_0.04_155)] px-2.5 py-1.5 text-xs font-semibold text-[oklch(35%_0.1_155)]">200 &times; 200px</div>
          <div class="rounded-full bg-[oklch(94%_0.006_250)] px-2.5 py-1.5 text-xs font-semibold text-[oklch(40%_0.02_250)]">SVG / PNG</div>
        </div>
      </div>
    </section>

    <!-- COMPACT LOCKUP -->
    <section class="bg-surface-alt px-[clamp(20px,5vw,40px)] py-15">
      <div class="mx-auto grid max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] items-center gap-12">
        <div>
          <div class="mb-2.5 text-lg font-bold">{t.badge.compactTitle}</div>
          <div class="text-sm leading-relaxed text-ink-muted">{t.badge.compactBody}</div>
        </div>
        <div class="flex items-center justify-center rounded-2xl border border-[oklch(91%_0.01_250)] bg-white p-8">
          <Seal locale={locale} variant="compact" />
        </div>
      </div>
    </section>

    <!-- DARK / MONOCHROME -->
    <section class="mx-auto grid w-full max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(240px,1fr))] items-center gap-12 px-[clamp(20px,5vw,40px)] py-15">
      <div class="flex items-center justify-center rounded-[20px] bg-[oklch(18%_0.02_250)] p-15">
        <Seal locale={locale} variant="dark" />
      </div>
      <div>
        <div class="mb-2.5 text-lg font-bold">{t.badge.darkTitle}</div>
        <div class="text-sm leading-relaxed text-ink-muted">{t.badge.darkBody}</div>
      </div>
    </section>

    <CtaBand locale={locale} heading={t.badge.ctaHeading} ctaLabel={t.badge.ctaButton} ctaHref="/apply/" />
  </main>
</Layout>
